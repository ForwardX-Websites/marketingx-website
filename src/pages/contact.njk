---
layout: layouts/base.njk
pageTitle: Contact
pageDescription: "Neem contact op met MarketingX — wij helpen je graag verder"
hasForm: true
extraCss: form.css
permalink: /contact/
---

<section class="section contact-hero">
  <div class="container">
    <div class="section__header reveal">
      <span class="section__eyebrow">Contact</span>
      <h1>Laten we kennismaken</h1>
      <p class="section__subtitle">
        Benieuwd wat MarketingX voor jouw bedrijf kan betekenen?
        Vul het formulier in of neem direct contact op.
      </p>
    </div>

    <div class="contact-layout">
      <div class="contact-layout__form reveal">
        {% include "components/contact-form.njk" %}
      </div>

      <div class="contact-layout__info reveal" style="--stagger-index: 1">
        <div class="contact-info">
          <h3>Contactgegevens</h3>
          <ul>
            <li>
              <strong>E-mail</strong>
              <a href="mailto:{{ site.contact.email }}">{{ site.contact.email }}</a>
            </li>
            <li>
              <strong>Telefoon</strong>
              <a href="tel:{{ site.contact.phone }}">{{ site.contact.phone }}</a>
            </li>
            <li>
              <strong>Adres</strong>
              <span>{{ site.contact.address.street }}<br>{{ site.contact.address.zip }} {{ site.contact.address.city }}</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
